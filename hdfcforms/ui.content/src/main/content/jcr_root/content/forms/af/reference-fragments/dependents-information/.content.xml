<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:fd="http://www.adobe.com/aemfd/fd/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/etc/designs/fd/af/default"
        cq:deviceGroups="mobile/groups/responsive"
        cq:template="/libs/fd/af/templateForFragment/defaultFragmentTemplate"
        jcr:primaryType="cq:PageContent"
        jcr:title="Dependents Information"
        sling:resourceType="fd/af/components/page/basePageForFragment">
        <guideContainer
            fd:version="1.1"
            jcr:primaryType="nt:unstructured"
            sling:resourceType="fd/af/components/guideFragmentContainer"
            guideCss="guideContainer"
            guideNodeClass="guideContainerNode"
            name="fragment1">
            <layout
                jcr:primaryType="nt:unstructured"
                sling:resourceType="fd/af/layouts/defaultGuideLayout"
                toolbarPosition="Bottom"/>
            <rootPanel
                jcr:primaryType="nt:unstructured"
                sling:resourceType="fd/af/components/rootPanel"
                guideNodeClass="rootPanelNode"
                name="guideRootPanel"
                panelSetType="Navigable">
                <layout
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="fd/af/layouts/gridFluidLayout2"
                    nonNavigable="true"
                    toolbarPosition="Bottom"/>
                <items jcr:primaryType="nt:unstructured">
                    <haveAnyDependents
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Do you have any dependents?"
                        sling:resourceType="fd/af/components/guideradiobutton"
                        _value="0"
                        guideNodeClass="guideRadioButton"
                        name="haveAnyDependents"
                        options="[0=Yes,1=No]"
                        textIsRich="[true,true]"/>
                    <dependentsDetailTable
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Dependents detail"
                        sling:resourceType="fd/af/components/table"
                        guideNodeClass="guideTable"
                        name="dependentsDetailTable"
                        textIsRich="true">
                        <layout
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="fd/af/layouts/tableLayout"
                            columns="2"
                            mobileLayout="collapsibleColumns"
                            nonNavigable="true"
                            rows="2"/>
                        <items
                            jcr:primaryType="nt:unstructured"
                            sling:resourceType="fd/af/layouts/tableLayout">
                            <HeaderRow
                                jcr:primaryType="nt:unstructured"
                                sling:resourceType="fd/af/components/tableHeader"
                                guideComponentType="true"
                                guideNodeClass="guideTableRow"
                                name="headerRow">
                                <layout
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/af/layouts/table/headerLayout"
                                    nonNavigable="true"/>
                                <items
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/af/layouts/table/headerLayout">
                                    <dependentNameHeader
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="fd/af/components/guidetextdraw"
                                        _value="&lt;p>Dependent name&lt;br>&#xd;&#xa;&lt;/p>&#xd;&#xa;"
                                        guideComponentType="true"
                                        guideNodeClass="guideTextDraw"
                                        name="dependentNameHeader"
                                        textIsRich="true"/>
                                    <dependentAgeHeader
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="fd/af/components/guidetextdraw"
                                        _value="&lt;p>Age&lt;/p>&#xd;&#xa;"
                                        guideComponentType="true"
                                        guideNodeClass="guideTextDraw"
                                        name="dependentAgeHeader"
                                        textIsRich="true"/>
                                    <dependentRelationshipHeader
                                        jcr:primaryType="nt:unstructured"
                                        sling:resourceType="fd/af/components/guidetextdraw"
                                        _value="&lt;p>Relationship&lt;/p>&#xd;&#xa;"
                                        guideComponentType="true"
                                        guideNodeClass="guideTextDraw"
                                        name="dependentRelationshipHeader"
                                        textIsRich="true"/>
                                </items>
                            </HeaderRow>
                            <dependentsDetailRow
                                jcr:primaryType="nt:unstructured"
                                jcr:title="Dependents detail row"
                                sling:resourceType="fd/af/components/tableRow"
                                guideComponentType="true"
                                guideNodeClass="guideTableRow"
                                maxOccur="5"
                                minOccur="1"
                                name="dependentsDetailRow">
                                <layout
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/af/layouts/table/rowLayout"
                                    nonNavigable="true"/>
                                <items
                                    jcr:primaryType="nt:unstructured"
                                    sling:resourceType="fd/af/layouts/table/rowLayout">
                                    <nameOfDependent
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Name of dependent"
                                        sling:resourceType="fd/af/components/guidetextbox"
                                        displayPatternType="none"
                                        guideComponentType="true"
                                        guideNodeClass="guideTextBox"
                                        hideTitle="true"
                                        mandatory="true"
                                        mandatoryMessage="Name is missing"
                                        name="nameOfDependent"
                                        placeholderText="Name"
                                        textIsRich="[true,true]"
                                        validationPatternType="none"/>
                                    <ageOfDependent
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Age of dependent"
                                        sling:resourceType="fd/af/components/guidenumericbox"
                                        displayPatternType="none"
                                        guideComponentType="true"
                                        guideNodeClass="guideNumericBox"
                                        hideTitle="true"
                                        mandatory="true"
                                        mandatoryMessage="This is a required field"
                                        name="ageOfDependent"
                                        placeholderText="Years"
                                        textIsRich="[true,true]"
                                        validationPatternType="none"/>
                                    <relationshipOfDependent
                                        jcr:primaryType="nt:unstructured"
                                        jcr:title="Relationship of Dependent"
                                        sling:resourceType="fd/af/components/guidedropdownlist"
                                        guideComponentType="true"
                                        guideNodeClass="guideDropDownList"
                                        hideTitle="true"
                                        mandatory="true"
                                        mandatoryMessage="Selection is required"
                                        name="relationshipOfDependent"
                                        options="[0=Spouse,1=Child,2=Parent,3=Other]"
                                        placeholderText="Select"
                                        textIsRich="[true,true]"/>
                                </items>
                            </dependentsDetailRow>
                        </items>
                        <fd:rules
                            fd:visible="[{&quot;nodeName&quot;:&quot;ROOT&quot;\,&quot;items&quot;:[{&quot;nodeName&quot;:&quot;STATEMENT&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;VISIBLE_EXPRESSION&quot;\,&quot;items&quot;:[{&quot;nodeName&quot;:&quot;AFCOMPONENT&quot;\,&quot;value&quot;:{&quot;id&quot;:&quot;FORM.guideRootPanel.dependentsDetailTable&quot;\,&quot;displayName&quot;:&quot;Dependents detail&quot;\,&quot;type&quot;:&quot;AFCOMPONENT&quot;\,&quot;displayPath&quot;:&quot;FORM/guideRootPanel/Dependents detail/&quot;\,&quot;name&quot;:&quot;dependentsDetailTable&quot;}}\,{&quot;nodeName&quot;:&quot;When&quot;\,&quot;value&quot;:null}\,{&quot;nodeName&quot;:&quot;CONDITIONORALWAYS&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;COMPARISON_EXPRESSION&quot;\,&quot;items&quot;:[{&quot;nodeName&quot;:&quot;EXPRESSION&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;COMPONENT&quot;\,&quot;value&quot;:{&quot;id&quot;:&quot;FORM.guideRootPanel.haveAnyDependents&quot;\,&quot;displayName&quot;:&quot;Do you have any dependents?&quot;\,&quot;type&quot;:&quot;STRING&quot;\,&quot;displayPath&quot;:&quot;FORM/guideRootPanel/Do you have any dependents?/&quot;\,&quot;name&quot;:&quot;haveAnyDependents&quot;}}}\,{&quot;nodeName&quot;:&quot;OPERATOR&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;EQUALS_TO&quot;\,&quot;value&quot;:null}}\,{&quot;nodeName&quot;:&quot;EXPRESSION&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;STRING_LITERAL&quot;\,&quot;value&quot;:&quot;1&quot;}}]}}\,{&quot;nodeName&quot;:&quot;Else&quot;\,&quot;value&quot;:null}\,{&quot;nodeName&quot;:&quot;DONOTHING_OR_SHOW&quot;\,&quot;choice&quot;:{&quot;nodeName&quot;:&quot;Show&quot;\,&quot;value&quot;:null}}]}}]\,&quot;isValid&quot;:true\,&quot;script&quot;:&quot;/**\\n\\n * This is a machine-generated code for the rule.\\n * If you modify it in the code editor\, you will not be able to view and edit the rule in the visual editor.\\n */\\n\\nif (haveAnyDependents.value == \\&quot;1\\&quot;) {\\n    false;\\n } else {\\n    true;\\n}\\n&quot;\,&quot;eventName&quot;:&quot;Visibility&quot;}]"
                            jcr:primaryType="nt:unstructured"/>
                    </dependentsDetailTable>
                </items>
            </rootPanel>
            <assets jcr:primaryType="nt:unstructured">
                <dictionary jcr:primaryType="nt:unstructured">
                    <de/>
                    <fr/>
                    <es/>
                </dictionary>
            </assets>
        </guideContainer>
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <smallScreen
                    jcr:primaryType="nt:unstructured"
                    title="Smaller Screen"
                    width="{Decimal}479"/>
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Phone"
                    width="{Decimal}767"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet"
                    width="{Decimal}991"/>
            </breakpoints>
        </cq:responsive>
    </jcr:content>
</jcr:root>
