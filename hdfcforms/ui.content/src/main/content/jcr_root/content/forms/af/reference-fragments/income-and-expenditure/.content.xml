<?xml version="1.0" encoding="UTF-8"?>
<jcr:root xmlns:sling="http://sling.apache.org/jcr/sling/1.0" xmlns:cq="http://www.day.com/jcr/cq/1.0" xmlns:jcr="http://www.jcp.org/jcr/1.0" xmlns:nt="http://www.jcp.org/jcr/nt/1.0"
    jcr:primaryType="cq:Page">
    <jcr:content
        cq:designPath="/etc/designs/fd/af/default"
        cq:deviceGroups="mobile/groups/responsive"
        cq:template="/libs/fd/af/templateForFragment/defaultFragmentTemplate"
        jcr:primaryType="cq:PageContent"
        jcr:title="Income &amp; Expenditure"
        sling:resourceType="fd/af/components/page/basePageForFragment">
        <guideContainer
            jcr:primaryType="nt:unstructured"
            sling:resourceType="fd/af/components/guideFragmentContainer"
            guideCss="guideContainer"
            guideNodeClass="guideContainerNode"
            name="fragment1">
            <layout
                jcr:primaryType="nt:unstructured"
                sling:resourceType="fd/af/layouts/defaultGuideLayout"
                toolbarPosition="Bottom"/>
            <rootPanel
                jcr:primaryType="nt:unstructured"
                sling:resourceType="fd/af/components/rootPanel"
                guideNodeClass="rootPanelNode"
                name="guideRootPanel"
                panelSetType="Navigable">
                <layout
                    jcr:primaryType="nt:unstructured"
                    sling:resourceType="fd/af/layouts/gridFluidLayout2"
                    nonNavigable="true"
                    toolbarPosition="Bottom"/>
                <items jcr:primaryType="nt:unstructured">
                    <financialDetailsMsg
                        jcr:primaryType="nt:unstructured"
                        sling:resourceType="fd/af/components/guidetextdraw"
                        _value="&lt;p>Please provide your financial details such as monthly income and expenditure.&lt;/p>&#xa;"
                        guideNodeClass="guideTextDraw"
                        name="financialDetailsMsg"
                        textIsRich="true"/>
                    <sourceOfIncome
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Source of income*"
                        sling:resourceType="fd/af/components/guidedropdownlist"
                        guideNodeClass="guideDropDownList"
                        mandatory="true"
                        mandatoryMessage="This is a required field"
                        name="sourceOfIncome"
                        options="[0=Employment,1=Inheritance,2=Trust,3=Investment Income,4=Retirement Income,5=Social Security,6=Other]"
                        placeholderText="Select"
                        textIsRich="[true,true]"/>
                    <preTaxIncome
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Total pre-tax monthly income*"
                        sling:resourceType="fd/af/components/guidenumericbox"
                        displayPatternType="custom"
                        displayPictureClause="num{$zz,zz,zz,zz,zz9.99}"
                        guideNodeClass="guideNumericBox"
                        longDescription="&lt;p>Please provide your income, before deduction of any taxes.&lt;br>&#xd;&#xa;&#xd;&#xa;&lt;/p>&#xd;&#xa;&#xd;&#xa;"
                        mandatory="true"
                        mandatoryMessage="This is a required field"
                        name="preTaxIncome"
                        placeholderText="$"
                        textIsRich="[true,true]"
                        validatePictureClauseMessage="Only numeric value can be entered"/>
                    <totalMonthlyExpenditure
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Total monthly expenditure*"
                        sling:resourceType="fd/af/components/guidenumericbox"
                        displayPatternType="custom"
                        displayPictureClause="num{$zz,zz,zz,zz,zz9.99}"
                        guideNodeClass="guideNumericBox"
                        longDescription="&lt;p>Monthly expenditure includes payments made towards your mortgage repayment/rent and payments towards bills and other utilities. Child support payments should also be included.&lt;/p>&#xd;&#xa;&#xd;&#xa;"
                        mandatory="true"
                        mandatoryMessage="This is a required field"
                        name="totalMonthlyExpenditure"
                        placeholderText="$"
                        textIsRich="[true,true]"
                        validatePictureClauseMessage="Only numeric value can be entered"/>
                    <totalAssetsValue
                        jcr:primaryType="nt:unstructured"
                        jcr:title="Total value of assets*"
                        sling:resourceType="fd/af/components/guidenumericbox"
                        displayPatternType="custom"
                        displayPictureClause="num{$zz,zz,zz,zz,zz9.99}"
                        guideNodeClass="guideNumericBox"
                        longDescription="&lt;p>Assets can include cash (account balance), investments (securities, stocks, insurance etc.) real estate, and other valuable equipment.&lt;br>&#xd;&#xa;&#xd;&#xa;&lt;/p>&#xd;&#xa;&#xd;&#xa;"
                        mandatory="true"
                        mandatoryMessage="This is a required field"
                        name="totalAssetsValue"
                        placeholderText="$"
                        textIsRich="[true,true]"
                        validatePictureClauseMessage="Only numeric value can be entered"
                        validationPatternType="none"/>
                </items>
            </rootPanel>
            <assets jcr:primaryType="nt:unstructured">
                <dictionary jcr:primaryType="nt:unstructured">
                    <fr/>
                    <de/>
                    <es/>
                </dictionary>
            </assets>
        </guideContainer>
        <cq:responsive jcr:primaryType="nt:unstructured">
            <breakpoints jcr:primaryType="nt:unstructured">
                <smallScreen
                    jcr:primaryType="nt:unstructured"
                    title="Smaller Screen"
                    width="{Decimal}479"/>
                <phone
                    jcr:primaryType="nt:unstructured"
                    title="Phone"
                    width="{Decimal}767"/>
                <tablet
                    jcr:primaryType="nt:unstructured"
                    title="Tablet"
                    width="{Decimal}991"/>
            </breakpoints>
        </cq:responsive>
    </jcr:content>
</jcr:root>
